public static int get_duration_of_program(String prog_code)
{
    int code = 0;
    switch(prog_code)
    {
        case "BIT":
        case "BME":
        case "BCE":
        case "BEE":
            code = 4;
            break;
        case "BCS":
        case "BCA":
            code = 3;
            break;
        case "MIT":
        case "MSC":
        case "MPC":
            code = 2;
            break;
        case "MIS":
        case "MSE":
            code = 5;
            break;
        
    }
    return code;
}

public static void main(String[] args)
{
    String thisYear = Year.now().toString();
    String [] reg = input();
    int join_year;
    String prog_code;
    String serial_number;
    int current_year = getDateYear(thisYear) + 1;
    
    
    for(int i = 0; i<reg.length; i++)
    {
        join_year = getYear(reg[i]);
        prog_code = getCode(reg[i]);
        serial_number = getProgramCode(reg[i]);
        
        
        int duration_of_program = get_duration_of_program(prog_code);
        
        if((join_year + duration_of_program) == (current_year))
        {
            System.out.println(reg[i] + " : Eligible for Placement due to Final Year Student");
        }
        else if((join_year + duration_of_program) < (current_year))
        {
            System.out.println(reg[i] + " : Not eligible for Placement due to Passedout(Duration Over) Student");
        }
        else
        {
            System.out.println(reg[i] + " : Not eligible for Placement due to " + (current_year-join_year) +" Year Student");
        }
        
    }
